# ── Sunucu tarafı (yalnız Next sunucusu okur, tarayıcıya sızmaz) ───────────────
# Next BFF'in Express backend'e ulaştığı temel URL ("/api" ile biter).
#   Yerel geliştirme:  http://localhost:3000/api
#   Prod (docker "edge" ağı):  http://bitir-yemek-app:3000/api
BACKEND_API_URL=http://localhost:3000/api

# ── Tarayıcıya açık (NEXT_PUBLIC_*) ────────────────────────────────────────────
# Mapbox erişim token'ı (işletme konum seçici haritası).
# Boş bırakılırsa harita yerine elle enlem/boylam girişi gösterilir.
NEXT_PUBLIC_MAPBOX_TOKEN=
