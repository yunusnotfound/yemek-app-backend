# Dependencies (reinstalled inside the image via npm ci)
node_modules
npm-debug.log*

# VCS / editor / OS cruft
.git
.gitignore
.vscode
.qoder
.DS_Store
**/.DS_Store

# Secrets and local env (provided at runtime via env_file / -e)
.env
.env.*
!.env.example

# Runtime-writable dirs (mounted as volumes, never baked into the image)
uploads
logs

# Docs and deployment scaffolding not needed inside the runtime image
*.md
Dockerfile
.dockerignore
docker-compose.yml
ecosystem.config.js
nginx

# The Flutter mobile app is a separate project
bitir_yemek_mobile

# Misc
.nvmrc
