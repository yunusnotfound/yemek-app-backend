PORT=3000
NODE_ENV=development

# Database - Option A: Individual vars (local development)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bitir_yemek
DB_USER=postgres
DB_PASSWORD=postgres

# Database - Option B: Connection string (Railway auto-provides this)
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# JWT - MUST be 32+ chars in production!
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google Sign-In
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Maps API (used by /api/maps/* geocoding, directions, and reverse-geocode endpoints)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# SendGrid Email
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM=your_verified_sender@example.com

# Redis (optional - Railway provides REDIS_URL)
# REDIS_URL=redis://default:pass@host:port
# REDIS_HOST=localhost
# REDIS_PORT=6379
