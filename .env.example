PORT=3000
NODE_ENV=development

# Database - Option A: Individual vars (local dev / self-hosted VPS Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bitir_yemek
DB_USER=postgres
DB_PASSWORD=postgres

# Database - Option B: Connection string (Railway/managed). Takes precedence if set.
# DATABASE_URL=postgresql://user:pass@host:port/dbname

# PostgreSQL SSL is OFF by default. Enable with DB_SSL=true or sslmode=require in DATABASE_URL.
# DB_SSL=true

# JWT - secrets MUST be 32+ chars in production! Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS - comma-separated allowlist of browser origins. REQUIRED in production for any web client.
# Native mobile apps send no Origin header and are unaffected. Do NOT use "*" in production.
# The Next.js web BFF talks to the API server-side (no browser Origin), so it is unaffected too;
# only set this if a browser calls the API directly.
CORS_ORIGIN=http://localhost:3000

# Public origin of THIS API (no trailing slash). Used to build absolute URLs for uploaded
# images (POST /api/upload). Behind Docker/Caddy the request host is an internal name, so set
# this explicitly in production, e.g. https://api.bitirgitsin.com. Falls back to the request
# host when unset (fine for local dev).
# PUBLIC_API_URL=https://api.bitirgitsin.com

# Swagger /api-docs is disabled in production unless this is "true".
# ENABLE_SWAGGER=false

# Google Sign-In
GOOGLE_CLIENT_ID=your_google_client_id_here

# Apple Sign-In - REQUIRED for Apple login. The app's Apple client/bundle id; tokens are
# verified against this audience. Apple login fails if unset.
APPLE_CLIENT_ID=com.bitiryemek.bitirYemekMobile

# Google Maps API (used by /api/maps/* geocoding, directions, and reverse-geocode endpoints)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Resend Email (transactional email — OTP login codes, order status, etc.)
# The sending domain must be verified in Resend (https://resend.com/domains).
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=Bitir Yemek <noreply@bitirgitsin.com>

# Sentry error tracking - optional. When set, unexpected (5xx) errors and
# uncaught exceptions are reported to Sentry. Leave empty to disable.
# SENTRY_DSN=https://xxxx@oyyy.ingest.sentry.io/zzzz
# SENTRY_RELEASE=
# Performance/APM sampling: 0 = errors only (default). e.g. 0.2 samples 20% of
# requests for endpoint latency/throughput. Raise while traffic is low.
# SENTRY_TRACES_SAMPLE_RATE=0.2

# Redis - optional, but STRONGLY recommended in production: refresh-token revocation
# fails closed (login refresh returns 401) in production when Redis is unavailable.
# REDIS_URL=redis://default:pass@host:port
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Docker Compose only (see docker-compose.yml / DEPLOYMENT.md) ---
# POSTGRES_DB=bitir_yemek
# POSTGRES_USER=bitir
# POSTGRES_PASSWORD=change_me_strong

# --- iyzico Pazaryeri (Marketplace) ödeme — SADECE sunucuda, asla istemciye verme ---
# Sandbox anahtarları (https://sandbox-merchant.iyzipay.com). Prod'da gerçek anahtarlar + Pazaryeri sözleşmesi gerekir.
IYZICO_API_KEY=sandbox-xxxxxxxxxxxxxxxx
IYZICO_SECRET_KEY=sandbox-xxxxxxxxxxxxxxxx
# Sandbox: https://sandbox-api.iyzipay.com  |  Prod: https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# iyzico -> backend callback (public HTTPS olmalı). Lokal test için ngrok/cloudflared tüneli kullan.
IYZICO_CALLBACK_URL=https://api.bitirgitsin.com/api/payments/iyzico/callback
# Webview'in algılayacağı sonuç sayfası (boşsa callback URL'inden türetilir).
# IYZICO_RESULT_URL=https://api.bitirgitsin.com/api/payments/result
# Webhook imza anahtarı (boşsa IYZICO_SECRET_KEY kullanılır). Zorunlu kılmak için IYZICO_WEBHOOK_ENFORCE=true.
# IYZICO_WEBHOOK_SECRET=
# IYZICO_WEBHOOK_ENFORCE=false
# Stok hold süresi (dk) — ödeme tamamlanmazsa reaper bu süre sonunda iptal eder.
IYZICO_HOLD_MINUTES=20
# Platform komisyon oranı (0.10 = %10). subMerchantPrice = finalPrice * (1 - oran).
PLATFORM_COMMISSION_RATE=0.10

# Web (Next.js) build arg — Mapbox token for the business location picker.
# Public value, baked into the client bundle at build time. Leave empty to fall
# back to manual lat/lng entry. (Consumed by the `web` service in docker-compose.yml.)
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxx
