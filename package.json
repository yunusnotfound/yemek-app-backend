{
  "name": "bitir-yemek",
  "version": "1.0.0",
  "description": "Bitir Yemek - food waste reduction platform REST API (Node.js/Express, Sequelize/PostgreSQL).",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:seed": "npx sequelize-cli db:seed:all",
    "deploy": "npm ci --omit=dev && npm run db:migrate"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@sentry/node": "^10.58.0",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "i18next": "^25.8.13",
    "i18next-http-middleware": "^3.9.2",
    "ioredis": "^5.9.3",
    "iyzipay": "^2.0.69",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pg": "^8.18.0",
    "pg-hstore": "^2.3.4",
    "resend": "^4.0.0",
    "sequelize": "^6.37.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
